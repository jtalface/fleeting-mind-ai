# Global
NODE_ENV=development
LOG_LEVEL=info

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000

# Web (VITE_* loaded from this same .env file)
WEB_PORT=5173
# Leave empty in dev so the browser uses the Vite proxy (5173 → 4000). Set only for direct API access.
VITE_API_BASE_URL=
VITE_TENANT_ID=tenant_demo
VITE_USER_ID=user_local

# Database and Queue
DATABASE_URL=postgresql://fleetmind:fleetmind@localhost:5432/fleetmind
REDIS_URL=redis://localhost:6379

# AI
OPENAI_API_KEY=replace-me
# e.g. gpt-4o-mini, gpt-4o — used only to rewrite answer prose (facts stay tool-grounded)
LLM_MODEL=gpt-4o-mini

# Multi-tenant default
DEFAULT_TENANT_ID=tenant_demo

# API storage: omit DATABASE_URL or set API_STORAGE=memory for in-memory dev
# API_STORAGE=memory

# Worker scheduler (optional — runs sync → analytics → forecast every 6h on 7d windows)
# WORKER_SCHEDULER_ENABLED=true
# WORKER_SCHEDULED_TENANT_IDS=tenant_demo
# WORKER_SCHEDULED_LOOKBACK_DAYS=7
# WORKER_SCHEDULED_FORECAST_HORIZON_DAYS=7
# WORKER_CRON_INTEGRATION_SYNC=0 */6 * * *
# WORKER_CRON_BATCH_ANALYTICS=15 */6 * * *
# WORKER_CRON_FORECAST_REFRESH=30 */6 * * *
# Weekly deep Flespi backfill (30d history for better MAPE)
# WORKER_CRON_DEEP_BACKFILL=0 3 * * 0
# WORKER_DEEP_BACKFILL_LOOKBACK_DAYS=30
# WORKER_DEEP_BACKFILL_DEVICE_INCLUDES=Sweeper

# Phase 4a — forecast training window (mart + score) vs hot KPI window
# FORECAST_TRAINING_LOOKBACK_DAYS=30
# ANALYTICS_HOT_LOOKBACK_DAYS=7
# WORKER_FORECAST_TRAINING_LOOKBACK_DAYS=30
# MART_QA_MIN_HISTORY_DAYS=14
# MART_QA_MIN_COVERAGE_PCT=50

# Phase 3 — forecast scopes (optional; omit segment env for fleet + top vehicles only)
# FORECAST_SEGMENT_SCOPES=[{"scopeKey":"Sweeper","nameIncludes":"Sweeper"}]
# FORECAST_TOP_VEHICLES=5
# WORKER_FORECAST_SEGMENT_SCOPES=[{"scopeKey":"Sweeper","nameIncludes":"Sweeper"}]
# WORKER_FORECAST_TOP_VEHICLES=5

# Telematics provider: flespi (recommended) or generic HTTP
INTEGRATIONS_PROVIDER=flespi

# Flespi — https://flespi.com/rest-api
# Authorization header: FlespiToken <token>
FLESPI_TOKEN=your-flespi-token
FLESPI_MESSAGES_PAGE_SIZE=200
# Backfill safety caps (first run: 10 devices × 3 pages × 200 msgs ≈ 6k points max)
FLESPI_SYNC_MAX_DEVICES=10
FLESPI_BACKFILL_LOOKBACK_DAYS=7
FLESPI_SYNC_MAX_PAGES_PER_DEVICE=3
FLESPI_SYNC_DELAY_MS=150

# Generic HTTP fleet metrics API (alternative to Flespi)
# FLEET_METRICS_API_BASE_URL=https://your-api.example.com
# FLEET_METRICS_API_KEY=replace-me
FLEET_METRICS_API_TIMEOUT_MS=30000
FLEET_METRICS_VEHICLES_PATH=/vehicles
FLEET_METRICS_TELEMETRY_PATH=/vehicles/{vehicleId}/telemetry
