{
  "name": "@fleetmind/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:seed": "dotenv -e ../../.env -- prisma db seed"
  },
  "dependencies": {
    "@fleetmind/shared": "workspace:*",
    "@prisma/client": "^5.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.20.0",
    "vitest": "^2.1.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
